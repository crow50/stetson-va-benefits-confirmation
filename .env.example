NODE_ENV=production

# Generate a strong random value for production
SESSION_SECRET=change-this-before-production

# RSA private key PEM - paste the full key, replacing newlines with \n
# e.g. -----BEGIN RSA PRIVATE KEY-----\nMIIE...\n-----END RSA PRIVATE KEY-----
VA_PRIVATE_KEY=

# Veteran Verification API (CCG client 1)
VA_CLIENT_ID=
VA_TOKEN_URL=https://sandbox-api.va.gov/oauth2/veteran-verification/system/v1/token
VA_AUDIENCE=https://deptva-eval.okta.com/oauth2/<auth-server-id>/v1/token
VA_API_BASE=https://sandbox-api.va.gov/services/veteran_verification/v2

# Letter Generator API (CCG client 2)
VA_LETTER_CLIENT_ID=
VA_LETTER_TOKEN_URL=https://sandbox-api.va.gov/oauth2/va-letter-generator/system/v1/token
VA_LETTER_AUDIENCE=https://deptva-eval.okta.com/oauth2/<auth-server-id>/v1/token
VA_LETTER_BASE=https://sandbox-api.va.gov/services/va-letter-generator/v1

# Education Benefits API (CCG client 3)
VA_EDUCATION_BENEFITS_CLIENT_ID=
VA_EDUCATION_BENEFITS_TOKEN_URL=https://sandbox-api.va.gov/oauth2/benefits-education/system/v1/token
VA_EDUCATION_BENEFITS_AUDIENCE=https://deptva-eval.okta.com/oauth2/<auth-server-id>/v1/token
VA_EDUCATION_BENEFITS_BASE=https://sandbox-api.va.gov/services/benefits-education/v1/education/chapter33
