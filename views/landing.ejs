<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { pageTitle: 'Stetson University - Veteran Benefits' }) %></head>
<body>
  <%- include('partials/header', { heading: 'Stetson University - Veteran Benefits' }) %>
  <main>
    <div class="landing">
      <div class="path-card">
        <h2>New Applicant / Guest</h2>
        <p>Look up VA benefits without signing in. For new applicants, dependents checking sponsor eligibility, or admissions staff.</p>
